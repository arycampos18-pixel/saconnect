# Copie para .env na VPS e no PC. Valores no painel do Supabase.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica
VITE_SUPABASE_PROJECT_ID=xxxx

# Opcional — OTP da pesquisa pública: se o browser/rede bloquear *.supabase.co,
# configure no Nginx o proxy (ver scripts/lightsail-setup.sh) e use CAMINHO RELATIVO
# (mesmo HTTPS que o site — nunca http:// num site servido em https://).
#VITE_PUBLIC_OTP_SEND_URL=/api/public-enviar-otp
