# Copie para .env na VPS e no PC. Valores no painel do Supabase.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica
VITE_SUPABASE_PROJECT_ID=xxxx

# URL canónica do site em produção (sem barra final). Usada em links/QR/WhatsApp (pesquisa /p/…,
# cadastro público) e redirects de auth, mesmo se o operador abrir o painel pelo IP da VPS.
# Ex.: VITE_PUBLIC_APP_URL=https://saconnect.net.br
#VITE_PUBLIC_APP_URL=

# OTP pesquisa pública — recomendado se aparecer "Falha de rede ao contactar o Supabase".
# Caminho relativo = mesmo host do site (Nginx em produção; Vite faz proxy em dev).
# Depois de alterar: npm run build (produção) ou reinicie npm run dev.
#VITE_PUBLIC_OTP_SEND_URL=/api/public-enviar-otp
