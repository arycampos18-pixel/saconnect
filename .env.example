# Copie para .env na VPS e no PC. Valores no painel do Supabase.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica
VITE_SUPABASE_PROJECT_ID=xxxx

# Opcional — OTP da pesquisa pública: se o browser/rede bloquear pedidos a *.supabase.co,
# crie no Nginx um reverse proxy no MESMO domínio do site e aponte para a Edge Function.
# Exemplo de URL: https://saconnect.net.br/api/public-enviar-otp
# (ver comentário em scripts/lightsail-setup.sh)
#VITE_PUBLIC_OTP_SEND_URL=https://SEU_DOMINIO/api/public-enviar-otp
